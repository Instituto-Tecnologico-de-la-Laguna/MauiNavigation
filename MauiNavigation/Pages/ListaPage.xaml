<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiNavigation.Pages.ListaPage"
             Title="ListaPage">
    <CollectionView x:Name="listaProductos"
                    Margin="12"
                    SelectionMode="Single"
                    SelectionChanged="OnProductoSeleccionado">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin=".6" CornerRadius="10" Padding="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding Nombre}"
                                   FontAttributes="Bold" FontSize="16"/>
                            <Label Text="{Binding Categoria}"
                                   TextColor="#888888" FontSize="13"/>                      
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="{Binding PrecioFormateado}"
                               FontAttributes="Bold"
                               TextColor="#1a7a4a"
                               FontSize="18"
                               VerticalOptions="Center"/>
                    </Grid>                    
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>        
    </CollectionView>
</ContentPage>